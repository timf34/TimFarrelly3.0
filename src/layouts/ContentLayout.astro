---
import Layout from './Layout.astro';
import Header from '../components/Header.astro';
import MobileNav from '../components/MobileNav.astro';
import ImageModal from '../components/ImageModal.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const currentPath = Astro.url.pathname;

// Determine which menu item should be active
const isLists = currentPath.startsWith('/lists');
const isWriting = currentPath.startsWith('/writing');
const isArt = currentPath.startsWith('/art');
const isPics = currentPath.startsWith('/pics');

// Check if we're on the exact index page (not a sub-page)
const isListsIndex = currentPath === '/lists' || currentPath === '/lists/';
const isWritingIndex = currentPath === '/writing' || currentPath === '/writing/';

// Determine current page for mobile nav
type PageKey = 'about' | 'lists' | 'writing' | 'art' | 'pics';
let currentPage: PageKey = 'about';
if (isLists) currentPage = 'lists';
else if (isWriting) currentPage = 'writing';
else if (isArt) currentPage = 'art';
else if (isPics) currentPage = 'pics';
---

<Layout title={title}>

  <!-- Header -->
  <Header />

  <!-- Mobile Navigation -->
  <MobileNav currentPage={currentPage} />

  <!-- Main Grid -->
  <main class="grid">

    <!-- Menu (centered in column 1) -->
    <nav class="col-menu">
      <ul>
        <li><a href="/">About</a></li>
        <li>{isListsIndex ? <strong>Lists</strong> : isLists ? <a href="/lists"><strong>Lists</strong></a> : <a href="/lists">Lists</a>}</li>
        <li>{isWritingIndex ? <strong>Writing</strong> : isWriting ? <a href="/writing"><strong>Writing</strong></a> : <a href="/writing">Writing</a>}</li>
        <li>{isArt ? <strong>Art Gallery</strong> : <a href="/art">Art Gallery</a>}</li>
        <li>{isPics ? <strong>Pics:)</strong> : <a href="/pics">Pics:)</a>}</li>
      </ul>
    </nav>

    <!-- Content (spans remaining width) -->
    <article class="col-content">
      <div class="content-inner prose">
        <slot />
      </div>
    </article>

  </main>

  <ImageModal />

  <script is:inline>
    // Auto-discover images in prose content and wire up modal click handlers
    (function () {
      var prose = document.querySelector('.prose');
      if (!prose) return;
      var imgs = Array.from(prose.querySelectorAll('img'));
      if (!imgs.length) return;
      var srcs = imgs.map(function (img) { return img.src; });
      imgs.forEach(function (img, i) {
        img.style.cursor = 'pointer';
        img.addEventListener('click', function () {
          if (window.openImageModal) window.openImageModal(srcs, i);
        });
      });
    })();
  </script>

</Layout>

<style>
  /* ===== GRID ===== */
  .grid {
    position: relative;
    padding-bottom: 4rem;
  }

  /* Menu - fixed position on left */
  .col-menu {
    position: absolute;
    left: 0;
    width: 10%;
    display: flex;
    justify-content: center;
  }

  .col-menu ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .col-menu li {
    margin-bottom: 0.5rem;
  }

  .col-menu a {
    text-decoration: none;
  }

  .col-menu a:hover {
    text-decoration: underline;
  }

  /* Content - centered on full page width, between 25% and 75% */
  .col-content {
    margin: 0 auto;
    width: 50%;
    max-width: 50%;
    padding: 0 1rem;
  }

  .content-inner {
    width: 100%;
  }

  /* Prose styles for markdown content - denser spacing */
  .prose :global(h1) {
    font-size: 1.75rem;
    margin: 0 0 0.75rem;
    font-weight: 600;
  }

  .prose :global(h2) {
    font-size: 1.35rem;
    margin: 1.25rem 0 0.5rem;
    font-weight: 600;
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    margin: 1rem 0 0.4rem;
    font-weight: 600;
  }

  .prose :global(p) {
    margin: 0 0 0.75rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 0.75rem;
    padding-left: 1.25rem;
  }

  .prose :global(li) {
    margin-bottom: 0.2rem;
  }

  /* Nested lists - even tighter */
  .prose :global(li ul),
  .prose :global(li ol) {
    margin: 0.15rem 0 0.15rem;
  }

  .prose :global(strong) {
    font-weight: 600;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    margin: 1rem 0;
    padding-left: 1rem;
    border-left: 3px solid rgba(14, 32, 47, 0.2);
    font-style: italic;
  }

  .prose :global(code) {
    font-family: "Roboto Mono", monospace;
    font-size: 0.9em;
    background: rgba(14, 32, 47, 0.05);
    padding: 0.15em 0.3em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    margin: 1rem 0;
    padding: 0.75rem;
    background: rgba(14, 32, 47, 0.05);
    border-radius: 6px;
    overflow-x: auto;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .prose :global(hr) {
    margin: 1.25rem 0;
    border: none;
    border-top: 1px solid rgba(14, 32, 47, 0.15);
  }

  /* Photo grid for blog posts */
  .prose :global(.photo-grid) {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.75rem;
    margin: 1.5rem 0;
  }

  .prose :global(.photo-grid img) {
    width: 100%;
    height: auto;
    border-radius: 4px;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  .prose :global(.photo-grid img:hover) {
    transform: scale(1.02);
  }

  /* ===== MOBILE ===== */
  @media (max-width: 900px) {
    .grid {
      display: block;
      padding: 0 1.5rem 3rem;
    }

    .col-menu {
      display: none;
    }

    .col-content {
      width: 100%;
      max-width: none;
      padding: 0;
    }

    .content-inner {
      width: 100%;
    }

    /* Photo grid stacks vertically on mobile */
    .prose :global(.photo-grid) {
      grid-template-columns: 1fr;
    }

    /* Image rows become horizontally scrollable carousels on mobile */
    .prose :global(.image-row) {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      -ms-overflow-style: none;
      flex-wrap: nowrap !important;
    }

    .prose :global(.image-row::-webkit-scrollbar) {
      display: none;
    }

    .prose :global(.image-row img) {
      flex: none !important;
      width: 75vw;
      max-width: 300px;
      height: 220px !important;
      scroll-snap-align: start;
    }
  }
</style>
